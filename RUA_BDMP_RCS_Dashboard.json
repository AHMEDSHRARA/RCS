<div class="foot-note" id="footNote" style="display:none;"></div>

<script>
/* ===================== STATE ===================== */
let CHARTS = {};
if(window.ChartDataLabels){
  Chart.register(ChartDataLabels);
  Chart.defaults.plugins.datalabels = Chart.defaults.plugins.datalabels || {};
  Chart.defaults.plugins.datalabels.display = false;
}
let SORT_STATE = { col:null, dir:1 };
/* Multi-select filter state — empty Set means "All" (no filtering). One pair for the Detail page,
   one pair for the Rounds Comparison page, kept independent so each view remembers its own selection. */
const MS_STATE = { msDiscipline: new Set(), msMilestone: new Set(), msRoundsDiscipline: new Set(), msRoundsMilestone: new Set() };
const MS_ONCHANGE = {};
const MS_ALLLABEL = {};

function buildMultiSelect(msId, values, allLabel, onChange){
  MS_ONCHANGE[msId] = onChange;
  MS_ALLLABEL[msId] = allLabel;
  const optionsEl = document.getElementById(msId+'Options');
  const selected = MS_STATE[msId];
  // drop any previously-selected values that no longer exist in the current option list
  [...selected].forEach(v=>{ if(!values.includes(v)) selected.delete(v); });

  optionsEl.innerHTML = values.map(v=>{
    const checked = selected.has(v) ? 'checked' : '';
    return `<label class="ms-option"><input type="checkbox" value="${escAttr(v)}" ${checked}> ${escHtml(v)}</label>`;
  }).join('');

  optionsEl.querySelectorAll('input[type=checkbox]').forEach(cb=>{
    cb.addEventListener('change', ()=>{
      if(cb.checked) selected.add(cb.value); else selected.delete(cb.value);
      updateMsToggleLabel(msId, allLabel);
      if(MS_ONCHANGE[msId]) MS_ONCHANGE[msId]();
    });
  });
  updateMsToggleLabel(msId, allLabel);
}
function updateMsToggleLabel(msId, allLabel){
  const toggleEl = document.getElementById(msId+'Toggle');
  const selected = MS_STATE[msId];
  if(selected.size===0){
    toggleEl.textContent = allLabel;
    toggleEl.classList.remove('has-selection');
  }else if(selected.size===1){
    toggleEl.textContent = shortenLabel([...selected][0]);
    toggleEl.classList.add('has-selection');
  }else{
    toggleEl.textContent = `${selected.size} selected`;
    toggleEl.classList.add('has-selection');
  }
}
function closeAllMsPanels(except){
  document.querySelectorAll('.ms-panel.open').forEach(p=>{ if(p.id!==except) p.classList.remove('open'); });
}
document.querySelectorAll('.ms-toggle').forEach(btn=>{
  btn.addEventListener('click', (e)=>{
    e.stopPropagation();
    const panel = btn.nextElementSibling;
    const willOpen = !panel.classList.contains('open');
    closeAllMsPanels(willOpen ? panel.id : null);
    panel.classList.toggle('open', willOpen);
  });
});
document.querySelectorAll('.ms-actions button').forEach(btn=>{
  btn.addEventListener('click', (e)=>{
    e.stopPropagation();
    const msId = btn.dataset.ms;
    const action = btn.dataset.action;
    const optionsEl = document.getElementById(msId+'Options');
    const checkboxes = optionsEl.querySelectorAll('input[type=checkbox]');
    const selected = MS_STATE[msId];
    checkboxes.forEach(cb=>{
      cb.checked = (action==='all');
      if(action==='all') selected.add(cb.value); else selected.delete(cb.value);
    });
    updateMsToggleLabel(msId, MS_ALLLABEL[msId] || 'All');
    if(MS_ONCHANGE[msId]) MS_ONCHANGE[msId]();
  });
});
document.addEventListener('click', ()=> closeAllMsPanels(null));

/* ===================== THEME ===================== */
function themeVar(name){ return getComputedStyle(document.documentElement).getPropertyValue(name).trim(); }
function isDarkMode(){ return document.documentElement.getAttribute('data-theme') === 'dark'; }
function safeGetStoredTheme(){ try{ return localStorage.getItem('rcs-dashboard-theme'); }catch(e){ return null; } }
function safeSetStoredTheme(mode){ try{ localStorage.setItem('rcs-dashboard-theme', mode); }catch(e){ /* storage unavailable */ } }
function applyChartJsThemeDefaults(){
  const textSoft = themeVar('--text-soft') || '#5b6478';
  const surface = themeVar('--surface') || '#ffffff';
  Chart.defaults.color = textSoft;
  Chart.defaults.borderColor = themeVar('--border') || '#d9d3c2';
  return { textSoft, surface };
}
function setTheme(mode){
  document.documentElement.setAttribute('data-theme', mode);
  safeSetStoredTheme(mode);
  document.getElementById('themeToggle').setAttribute('aria-pressed', mode==='dark' ? 'true' : 'false');
  applyChartJsThemeDefaults();
  if(RCS_DATA){
    destroyCharts();
    renderOverviewCharts();
    renderRoundsCompareTab();
    renderHeatmap();
  }
}
(function initTheme(){
  const saved = safeGetStoredTheme();
  const preferred = saved || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  document.documentElement.setAttribute('data-theme', preferred);
  document.getElementById('themeToggle').setAttribute('aria-pressed', preferred==='dark' ? 'true' : 'false');
  applyChartJsThemeDefaults();
})();

const STATUS_COLORS = {
  'Approved':'var(--status-a)',
  'Approved with Comments':'var(--status-b)',
  'Revise & Resubmit':'var(--status-c)',
  'Rejected':'var(--status-d)',
  'No Data':'var(--status-n)'
};
const STATUS_HEX = {
  'Approved':'#92D050',
  'Approved with Comments':'#FFFF00',
  'Revise & Resubmit':'#FFC000',
  'Rejected':'#FF0000',
  'No Data':'#a8a39a'
};
const STATUS_TEXT = {
  'Approved':'#1a2233',
  'Approved with Comments':'#1a2233',
  'Revise & Resubmit':'#1a2233',
  'Rejected':'#ffffff',
  'No Data':'#1a2233'
};
function colorForStatus(s){ return STATUS_HEX[s] || '#a8a39a'; }
function textColorForStatus(s){ return STATUS_TEXT[s] || '#1a2233'; }
function ratingFromPct(pct){
  if(pct >= 90) return {label:'Approved', code:'A'};
  if(pct >= 75) return {label:'Approved with Comments', code:'B'};
  if(pct >= 50) return {label:'Revise & Resubmit', code:'C'};
  return {label:'Rejected', code:'D'};
}
/* The RCS tab's own Status formula only checks whether Total Comments (all logged, not this-round-reviewed)
   is zero — so a round nobody has touched yet still shows "Rejected" rather than "No Data". These helpers
   correct that at display time: whenever nothing has a disposition entered for this round, treat it as
   genuinely "No Data" instead of trusting the workbook's literal (misleading) text. */
function reviewedCount(row){ return row.a + row.b + row.c + row.d; }
function effectiveStatus(row){ return reviewedCount(row)===0 ? 'No Data' : row.status; }
function effectiveRating(row){ return reviewedCount(row)===0 ? null : row.rating; }

/* ===================== PARSE — reads the RCS tab's own 4 review-summary blocks directly ===================== */
const ROUNDS = ['R1','R2','R3','Final'];
/* 0-indexed column map for each round's block in the RCS tab (Pending column intentionally skipped — not surfaced in this dashboard) */
const RCS_BLOCKS = {
  R1:    { disc:0,  stage:1,  milestone:2,  total:3,  a:4,  b:5,  c:6,  d:7,  rating:9,  status:10, critTotal:11, high:12, medium:13, low:14 },
  R2:    { disc:16, stage:17, milestone:18, total:19, a:20, b:21, c:22, d:23, rating:25, status:26, critTotal:27, high:28, medium:29, low:30 },
  R3:    { disc:32, stage:33, milestone:34, total:35, a:36, b:37, c:38, d:39, rating:41, status:42, critTotal:43, high:44, medium:45, low:46 },
  Final: { disc:48, stage:49, milestone:50, total:51, a:52, b:53, c:54, d:55, rating:57, status:58, critTotal:59, high:60, medium:61, low:62 }
};
const DETAIL_ROW_START = 16;   // row 17 — first discipline/Step I row
const DETAIL_ROW_END   = 130;  // row 131 — last discipline/TOTAL row (23 disciplines x 5 rows)
const SUMMARY_ROW_START = 133; // row 134 — Baseline Step I rollup
const SUMMARY_ROW_END   = 137; // row 138 — Baseline TOTAL rollup

function numOr0(v){ const n = Number(v); return isFinite(n) ? n : 0; }

function parseRCS(workbook){
  const ws = workbook.Sheets['RCS'];
  if(!ws) throw new Error('This workbook does not contain an "RCS" tab.');
  const all = XLSX.utils.sheet_to_json(ws, {header:1, defval:null});

  const detailByRound = {R1:[], R2:[], R3:[], Final:[]};
  const summaryByRound = {R1:[], R2:[], R3:[], Final:[]}; // Step I..IV + TOTAL rollup across all workstreams

  ROUNDS.forEach(rnd=>{
    const cols = RCS_BLOCKS[rnd];

    for(let i=DETAIL_ROW_START; i<=DETAIL_ROW_END; i++){
      const r = all[i];
      if(!r) continue;
      const disc = r[cols.disc];
      if(disc===null || disc===undefined || String(disc).trim()==='') continue;
      const stageRaw = String(r[cols.stage] ?? '').trim();
      const isTotal = stageRaw.toUpperCase()==='TOTAL';
      const milestoneRaw = r[cols.milestone];
      detailByRound[rnd].push({
        discipline: String(disc).trim(),
        stage: isTotal ? 'Baseline' : stageRaw,   // TOTAL rows still belong to the Baseline stage conceptually
        milestone: isTotal ? 'TOTAL' : String(milestoneRaw ?? '').trim(),
        total: numOr0(r[cols.total]),
        a: numOr0(r[cols.a]), b: numOr0(r[cols.b]), c: numOr0(r[cols.c]), d: numOr0(r[cols.d]),
        rating: numOr0(r[cols.rating]),
        status: r[cols.status] || 'No Data',
        critTotal: numOr0(r[cols.critTotal]), high: numOr0(r[cols.high]), medium: numOr0(r[cols.medium]), low: numOr0(r[cols.low]),
        isTotal, round: rnd
      });
    }

    for(let i=SUMMARY_ROW_START; i<=SUMMARY_ROW_END; i++){
      const r = all[i];
      if(!r) continue;
      const milestoneRaw = String(r[cols.milestone] ?? '').trim();
      const isTotal = milestoneRaw.toUpperCase()==='TOTAL';
      summaryByRound[rnd].push({
        stage: 'Baseline',
        milestone: isTotal ? 'TOTAL' : milestoneRaw,
        total: numOr0(r[cols.total]),
        a: numOr0(r[cols.a]), b: numOr0(r[cols.b]), c: numOr0(r[cols.c]), d: numOr0(r[cols.d]),
        rating: numOr0(r[cols.rating]),
        status: r[cols.status] || 'No Data',
        critTotal: numOr0(r[cols.critTotal]), high: numOr0(r[cols.high]), medium: numOr0(r[cols.medium]), low: numOr0(r[cols.low]),
        isTotal, round: rnd
      });
    }
  });

  const totalDetailRows = Object.values(detailByRound).reduce((s,a)=>s+a.length,0);
  if(totalDetailRows === 0) throw new Error('The RCS tab was found, but no discipline rows could be parsed. Check that its layout still matches the expected R1/R2/R3/Final review-summary blocks (rows 17-131).');

  return { detailByRound, summaryByRound };
}

function parseWorkbook(workbook, fileLabel){
  const data = parseRCS(workbook);
  const discCount = new Set(data.detailByRound.R1.filter(r=>r.isTotal).map(r=>r.discipline)).size;
  return { ...data, fileLabel, sheetName: `RCS tab · ${discCount} workstreams` };
}

/* ===================== AGGREGATION HELPERS (all read straight from the RCS tab's own computed values) ===================== */
function getOverall(round){
  return RCS_DATA.summaryByRound[round].find(r=>r.milestone==='TOTAL');
}
function getMilestoneRollup(round){
  return RCS_DATA.summaryByRound[round].filter(r=>r.milestone!=='TOTAL');
}
function getWorkstreamTotals(round){
  return RCS_DATA.detailByRound[round].filter(r=>r.isTotal);
}
function getStepRows(round){
  return RCS_DATA.detailByRound[round].filter(r=>!r.isTotal);
}
function getStageRollup(round){
  const totals = getWorkstreamTotals(round);
  const byStage = {};
  totals.forEach(r=>{
    if(!byStage[r.stage]) byStage[r.stage] = {stage:r.stage, total:0, a:0, b:0, c:0, d:0, critTotal:0, high:0, medium:0, low:0};
    const s = byStage[r.stage];
    s.total += r.total; s.a += r.a; s.b += r.b; s.c += r.c; s.d += r.d;
    s.critTotal += r.critTotal; s.high += r.high; s.medium += r.medium; s.low += r.low;
  });
  return Object.values(byStage);
}

/* Sums an arbitrary set of Step-level rows into a single {total,a,b,c,d,critTotal,high,medium,low,rating,status}
   record, using the same (A+B)/Total-logged convention as every other rating in this dashboard. */
function aggregateStepRows(rows){
  const agg = {total:0, a:0, b:0, c:0, d:0, critTotal:0, high:0, medium:0, low:0};
  rows.forEach(r=>{
    agg.total += r.total; agg.a += r.a; agg.b += r.b; agg.c += r.c; agg.d += r.d;
    agg.critTotal += r.critTotal; agg.high += r.high; agg.medium += r.medium; agg.low += r.low;
  });
  agg.rating = agg.total>0 ? (agg.a+agg.b)/agg.total : 0;
  agg.status = agg.total===0 ? 'No Data' : ratingFromPct(agg.rating*100).label;
  return agg;
}
/* Overall figures for a round, scoped to a Discipline/Milestone selection. Empty sets = no filter = whole programme,
   which reduces to exactly the RCS tab's own precomputed grand total (Step-level rows always sum to it). */
function getFilteredOverall(round, discSet, mileSet){
  let rows = getStepRows(round);
  if(discSet && discSet.size>0) rows = rows.filter(r=>discSet.has(r.discipline));
  if(mileSet && mileSet.size>0) rows = rows.filter(r=>mileSet.has(r.milestone));
  return aggregateStepRows(rows);
}
/* Same idea, scoped to one discipline (for the per-workstream round matrix) */
function getFilteredDisciplineAgg(round, discipline, mileSet){
  let rows = getStepRows(round).filter(r=>r.discipline===discipline);
  if(mileSet && mileSet.size>0) rows = rows.filter(r=>mileSet.has(r.milestone));
  return aggregateStepRows(rows);
}

/* ===================== RENDER ORCHESTRATION ===================== */
function destroyCharts(){
  Object.values(CHARTS).forEach(c => c && c.destroy());
  CHARTS = {};
}

let RCS_DATA = null;
let ACTIVE_ROUND = 'R1';
let LAST_FILE_META = null;

function renderAll(data){
  RCS_DATA = data;
  ACTIVE_ROUND = 'R1';
  LAST_FILE_META = data;
  document.getElementById('emptyState').classList.remove('active');
  document.getElementById('viewnav').style.display = 'flex';
  document.getElementById('roundSelector').style.display = 'flex';
  document.getElementById('footNote').style.display = 'block';
  switchView('overview');
  setActiveRound('R1');
  renderRoundsCompareTab();
}

function setActiveRound(round){
  ACTIVE_ROUND = round;
  document.querySelectorAll('.round-pill').forEach(b=>b.classList.toggle('active', b.dataset.round===round));

  const overall = getOverall(round);
  const roundLabel = round==='R1' ? 'comments logged' : 'comments with a disposition entered this round';
  document.getElementById('footNote').textContent =
    `Source: ${LAST_FILE_META.fileLabel} · ${LAST_FILE_META.sheetName} · Viewing ${round} · ${(overall.a+overall.b+overall.c+overall.d).toLocaleString()} ${roundLabel} · Parsed client-side, nothing uploaded to a server.`;

  destroyCharts();
  renderKPIs();
  renderStageRatings();
  renderMilestoneRatings();
  renderOverviewCharts();
  populateFilters();
  renderTable();
  renderHeatmap();
}

function switchView(name){
  document.querySelectorAll('.viewnav button').forEach(b=>b.classList.toggle('active', b.dataset.view===name));
  document.querySelectorAll('.view').forEach(v=>v.id==='view-'+name ? v.classList.add('active') : (v.id.startsWith('view-')&&v.classList.remove('active')));
}

/* ===================== KPIs (Overall) ===================== */
function renderKPIs(){
  const overall = getOverall(ACTIVE_ROUND);
  const workstreams = getWorkstreamTotals(ACTIVE_ROUND);
  const reviewedWorkstreams = workstreams.filter(r=>reviewedCount(r)>0).length;
  const atRisk = workstreams.filter(r=>effectiveStatus(r)==='Revise & Resubmit' || effectiveStatus(r)==='Rejected').length;
  const eStatus = effectiveStatus(overall);
  const eRating = effectiveRating(overall);
  const pct = eRating===null ? null : Math.round(eRating*100);

  const kpis = [
    {num:overall.total.toLocaleString(), lbl:'Total Comments Logged', sub:`Across ${workstreams.length} workstreams`, cls:''},
    {num:pct===null ? '—' : pct+'%', lbl:'Approval Rating (A + B)', sub:pct===null ? 'No comments reviewed yet' : eStatus, cls: (eStatus==='Rejected'||eStatus==='Revise & Resubmit') ? 'bad' : ''},
    {num:overall.critTotal.toLocaleString(), lbl:'Critical Open Comments', sub:`${overall.high.toLocaleString()} High · ${overall.medium.toLocaleString()} Medium · ${overall.low.toLocaleString()} Low`, cls:overall.critTotal>0?'bad':''},
    {num:reviewedWorkstreams+' / '+workstreams.length, lbl:'Workstreams Reviewed', sub:`${ACTIVE_ROUND} disposition entered`, cls:''},
    {num:atRisk+' / '+workstreams.length, lbl:'Workstreams At Risk', sub:'Revise & Resubmit or Rejected', cls:atRisk>0?'warn':''}
  ];

  document.getElementById('kpiRow').innerHTML = kpis.map(k=>`
    <div class="kpi ${k.cls}">
      <div class="num">${k.num}</div>
      <div class="lbl">${k.lbl}</div>
      <div class="sub">${k.sub}</div>
    </div>
  `).join('');
}

/* ===================== APPROVAL STATUS BY STAGE ===================== */
function renderStageRatings(){
  const stages = getStageRollup(ACTIVE_ROUND);
  document.getElementById('stageRatingRow').innerHTML = stages.map(s=>{
    const total = s.a+s.b+s.c+s.d;
    if(total===0){
      return `
        <div class="rating-card no-data" style="border-top-color:var(--status-n);">
          <div class="step-lbl">${escHtml(s.stage)}</div>
          <div class="pct">—</div>
          <div class="pct-lbl">No comments reviewed yet</div>
        </div>`;
    }
    const pct = (s.a+s.b)/total*100;
    const rating = ratingFromPct(pct);
    const color = colorForStatus(rating.label);
    const textColor = textColorForStatus(rating.label);
    return `
      <div class="rating-card" style="border-top-color:${color};">
        <div class="step-lbl">${escHtml(s.stage)}</div>
        <div class="pct">${pct.toFixed(1)}%</div>
        <div class="pct-lbl">(A+B) of ${s.total.toLocaleString()} comments</div>
        <span class="rating-chip" style="background:${color};color:${textColor};">${rating.label}</span>
      </div>`;
  }).join('');
}

/* ===================== APPROVAL STATUS BY MILESTONE ===================== */
function renderMilestoneRatings(){
  const rows = getMilestoneRollup(ACTIVE_ROUND);
  document.getElementById('milestoneRatingRow').innerHTML = rows.map(row=>{
    const eRating = effectiveRating(row);
    if(eRating===null){
      return `
        <div class="rating-card no-data" style="border-top-color:var(--status-n);">
          <div class="step-lbl">${escHtml(row.milestone)}</div>
          <div class="pct">—</div>
          <div class="pct-lbl">No comments reviewed yet</div>
        </div>`;
    }
    const eStatus = effectiveStatus(row);
    const pct = eRating*100;
    const color = colorForStatus(eStatus);
    const textColor = textColorForStatus(eStatus);
    return `
      <div class="rating-card" style="border-top-color:${color};">
        <div class="step-lbl">${escHtml(row.milestone)}</div>
        <div class="pct">${pct.toFixed(1)}%</div>
        <div class="pct-lbl">(A+B) of ${reviewedCount(row).toLocaleString()} reviewed comments</div>
        <span class="rating-chip" style="background:${color};color:${textColor};">${eStatus}</span>
      </div>`;
  }).join('');
}

/* ===================== OVERVIEW CHARTS ===================== */
function renderOverviewCharts(){
  const milestoneRows = getMilestoneRollup(ACTIVE_ROUND).filter(r=>(r.a+r.b+r.c+r.d)>0);
  CHARTS.milestone = new Chart(document.getElementById('chartMilestone'), {
    type:'bar',
    data:{
      labels: milestoneRows.map(r=>r.milestone),
      datasets:[
        {label:'A — Approved', data:milestoneRows.map(r=>r.a), backgroundColor:STATUS_HEX['Approved']},
        {label:'B — Approved w/ Comments', data:milestoneRows.map(r=>r.b), backgroundColor:STATUS_HEX['Approved with Comments']},
        {label:'C — Revise & Resubmit', data:milestoneRows.map(r=>r.c), backgroundColor:STATUS_HEX['Revise & Resubmit']},
        {label:'D — Rejected', data:milestoneRows.map(r=>r.d), backgroundColor:STATUS_HEX['Rejected']}
      ]
    },
    options:baseBarOptions(true)
  });

  const overall = getOverall(ACTIVE_ROUND);
  CHARTS.statusPie = new Chart(document.getElementById('chartStatusPie'), {
    type:'doughnut',
    data:{
      labels:['A — Approved','B — Approved w/ Comments','C — Revise & Resubmit','D — Rejected'],
      datasets:[{data:[overall.a,overall.b,overall.c,overall.d], backgroundColor:[STATUS_HEX['Approved'],STATUS_HEX['Approved with Comments'],STATUS_HEX['Revise & Resubmit'],STATUS_HEX['Rejected']], borderWidth:2, borderColor:themeVar('--surface')}]
    },
    options:basePieOptions()
  });

  CHARTS.severityPie = new Chart(document.getElementById('chartSeverityPie'), {
    type:'doughnut',
    data:{
      labels:['High','Medium','Low'],
      datasets:[{data:[overall.high,overall.medium,overall.low], backgroundColor:['#b5453f','#d98f3c','#9aa688'], borderWidth:2, borderColor:themeVar('--surface')}]
    },
    options: (overall.high+overall.medium+overall.low)===0 ? noDataOptions() : {
      ...basePieOptions(),
      plugins:{
        ...basePieOptions().plugins,
        datalabels:{
          display:(ctx)=>ctx.dataset.data[ctx.dataIndex] > 0,
          color:(ctx)=> ctx.dataIndex===1 ? '#1a2233' : '#fff',
          font:{weight:700, size:13},
          formatter:(value)=> value.toLocaleString()
        }
      }
    }
  });

  const workstreams = getWorkstreamTotals(ACTIVE_ROUND);
  const statusOrder = ['Approved','Approved with Comments','Revise & Resubmit','Rejected','No Data'];
  const statusCounts = statusOrder.map(s => workstreams.filter(r=>effectiveStatus(r)===s).length);
  CHARTS.ratingHist = new Chart(document.getElementById('chartRatingHist'), {
    type:'bar',
    data:{
      labels: statusOrder.map(s=>s==='Approved with Comments' ? 'Approved w/ Comments' : s),
      datasets:[{
        label:'Workstreams',
        data: statusCounts,
        backgroundColor: statusOrder.map(s => s==='No Data' ? '#a8a39a' : colorForStatus(s)),
        borderRadius:2
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{callbacks:{label:(ctx)=>`${ctx.parsed.y} workstream${ctx.parsed.y===1?'':'s'}`}},
        datalabels:{
          display:(ctx)=>ctx.dataset.data[ctx.dataIndex] > 0,
          anchor:'end', align:'top',
          color:themeVar('--text-soft'), font:{weight:700, size:12},
          formatter:(value)=> value
        }
      },
      scales:{ y:{beginAtZero:true, ticks:{precision:0}, grid:{color:themeVar('--chart-grid')}}, x:{grid:{display:false}, ticks:{font:{size:10.5}, maxRotation:20, minRotation:0}} }
    }
  });

  const sorted = [...workstreams].sort((x,y)=>y.total-x.total);
  const labels = sorted.map(r=>shortenLabel(r.discipline));
  if(CHARTS.disciplineStacked) CHARTS.disciplineStacked.destroy();
  CHARTS.disciplineStacked = new Chart(document.getElementById('chartDisciplineStacked'), {
    type:'bar',
    data:{
      labels,
      datasets:[
        {label:'A', data:sorted.map(r=>r.a), backgroundColor:STATUS_HEX['Approved']},
        {label:'B', data:sorted.map(r=>r.b), backgroundColor:STATUS_HEX['Approved with Comments']},
        {label:'C', data:sorted.map(r=>r.c), backgroundColor:STATUS_HEX['Revise & Resubmit']},
        {label:'D', data:sorted.map(r=>r.d), backgroundColor:STATUS_HEX['Rejected']}
      ]
    },
    options:{
      indexAxis:'y',
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}, tooltip:{mode:'index', intersect:false}},
      scales:{
        x:{stacked:true, beginAtZero:true, grid:{color:themeVar('--chart-grid')}},
        y:{stacked:true, grid:{display:false}, ticks:{font:{size:11}}}
      }
    }
  });
}

/* shared chart option builders */
function baseBarOptions(stacked){
  return {
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{position:'bottom', labels:{boxWidth:10,font:{size:11}}}, tooltip:{mode:'index', intersect:false} },
    scales:{
      x:{stacked, grid:{display:false}},
      y:{stacked, beginAtZero:true, grid:{color:themeVar('--chart-grid')}}
    }
  };
}
function basePieOptions(){
  return { responsive:true, maintainAspectRatio:false, cutout:'58%',
    plugins:{ legend:{position:'bottom', labels:{boxWidth:10,font:{size:11}, padding:10}},
      tooltip:{callbacks:{label:(ctx)=>{
        const total = ctx.dataset.data.reduce((a,b)=>a+b,0);
        const pct = total? Math.round((ctx.parsed/total)*100):0;
        return `${ctx.label}: ${ctx.parsed.toLocaleString()} (${pct}%)`;
      }}}
    }
  };
}
function noDataOptions(){
  return { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{display:false},y:{display:false}} };
}
function shortenLabel(name){
  if(!name) return '';
  return String(name).replace(/^V\d?(\.\d+)?\.?\s*/i,'').replace(/^V[\d\.x]+\.\s*/i,'').trim() || name;
}

/* ===================== DISCIPLINE × MILESTONE TABLE ===================== */
const COLS = [
  {key:'discipline', label:'Discipline'},
  {key:'stage', label:'Stage'},
  {key:'milestone', label:'Milestone'},
  {key:'total', label:'Total', num:true},
  {key:'a', label:'A', num:true},
  {key:'b', label:'B', num:true},
  {key:'c', label:'C', num:true},
  {key:'d', label:'D', num:true},
  {key:'rating', label:'Rating', num:true, pct:true},
  {key:'status', label:'Status'},
  {key:'critTotal', label:'Critical Total', num:true},
  {key:'high', label:'High', num:true},
  {key:'medium', label:'Medium', num:true},
  {key:'low', label:'Low', num:true}
];

function populateFilters(){
  const rows = getStepRows(ACTIVE_ROUND);
  const disc = [...new Set(rows.map(r=>r.discipline))].sort();
  const stat = [...new Set(RCS_DATA.detailByRound[ACTIVE_ROUND].map(r=>effectiveStatus(r)))].sort();
  const mile = [...new Set(rows.map(r=>r.milestone))];
  const onChange = ()=>{ renderTable(); renderHeatmap(); };
  buildMultiSelect('msDiscipline', disc, 'All Disciplines', onChange);
  buildMultiSelect('msMilestone', mile, 'All Milestones', onChange);
  fillSelect('filterStatus', stat);
}
function fillSelect(id, values){
  const sel = document.getElementById(id);
  const prev = sel.value;
  sel.innerHTML = '<option value="">All</option>' + values.map(v=>`<option value="${escAttr(v)}">${escHtml(v)}</option>`).join('');
  if(values.includes(prev)) sel.value = prev;
}

function renderTable(){
  const head = document.getElementById('tableHead');
  head.innerHTML = COLS.map(c=>`<th data-key="${c.key}">${c.label}<span class="arrow">${SORT_STATE.col===c.key ? (SORT_STATE.dir===1?'▲':'▼') : ''}</span></th>`).join('');

  const discSel = MS_STATE.msDiscipline;
  const mileSel = MS_STATE.msMilestone;
  const statF = document.getElementById('filterStatus').value;
  const searchF = document.getElementById('filterSearch').value.trim().toLowerCase();

  let rows = [...RCS_DATA.detailByRound[ACTIVE_ROUND]];
  if(discSel.size>0) rows = rows.filter(r=>discSel.has(r.discipline));
  if(statF) rows = rows.filter(r=>effectiveStatus(r)===statF);
  if(mileSel.size>0) rows = rows.filter(r=>mileSel.has(r.milestone));
  if(searchF) rows = rows.filter(r=>r.discipline.toLowerCase().includes(searchF));

  if(SORT_STATE.col){
    rows.sort((x,y)=>{
      const kx = x[SORT_STATE.col], ky = y[SORT_STATE.col];
      if(typeof kx === 'number') return (kx-ky)*SORT_STATE.dir;
      return String(kx).localeCompare(String(ky))*SORT_STATE.dir;
    });
  }

  const body = document.getElementById('tableBody');
  body.innerHTML = rows.map(r=>{
    const eStatus = effectiveStatus(r);
    const eRating = effectiveRating(r);
    const chip = `<span class="status-chip" style="background:${colorForStatus(eStatus)};color:${textColorForStatus(eStatus)};">${escHtml(eStatus)}</span>`;
    const critCell = r.critTotal>0 ? `<span class="crit-badge has-crit">${r.critTotal}</span>` : r.critTotal;
    return `<tr class="${r.isTotal?'row-total':''}">
      <td>${escHtml(shortenLabel(r.discipline))}</td>
      <td>${escHtml(r.stage)}</td>
      <td>${escHtml(r.milestone)}</td>
      <td>${r.total.toLocaleString()}</td>
      <td>${r.a}</td>
      <td>${r.b}</td>
      <td>${r.c}</td>
      <td>${r.d}</td>
      <td>${eRating===null ? '—' : (eRating*100).toFixed(1)+'%'}</td>
      <td>${chip}</td>
      <td>${critCell}</td>
      <td>${r.high}</td>
      <td>${r.medium}</td>
      <td>${r.low}</td>
    </tr>`;
  }).join('') || `<tr><td colspan="${COLS.length}" style="text-align:center;color:var(--ink-soft);padding:30px;">No rows match the current filters.</td></tr>`;

  head.querySelectorAll('th').forEach(th=>{
    th.addEventListener('click', ()=>{
      const key = th.dataset.key;
      if(SORT_STATE.col===key) SORT_STATE.dir *= -1;
      else { SORT_STATE.col = key; SORT_STATE.dir = 1; }
      renderTable();
    });
  });
}

/* ===================== HEATMAP — Workstream x Milestone ===================== */
function renderHeatmap(){
  const allSteps = ['Step I','Step II','Step III','Step IV'];
  const mileSel = MS_STATE.msMilestone;
  const discSel = MS_STATE.msDiscipline;
  const stepOrder = mileSel.size>0 ? allSteps.filter(s=>mileSel.has(s)) : allSteps;
  const stepRows = getStepRows(ACTIVE_ROUND);
  const workstreamTotals = getWorkstreamTotals(ACTIVE_ROUND)
    .filter(r=> discSel.size===0 || discSel.has(r.discipline));
  const workstreams = workstreamTotals.map(r=>r.discipline); // preserves RCS tab order

  const head = document.getElementById('heatmapHead');
  head.innerHTML = '<th>Workstream</th>' + stepOrder.map(s=>`<th>${s}</th>`).join('') + '<th>TOTAL</th>';

  const body = document.getElementById('heatmapBody');
  if(workstreams.length===0 || stepOrder.length===0){
    body.innerHTML = `<tr><td colspan="${stepOrder.length+2}" style="text-align:center;color:var(--ink-soft);padding:24px;background:var(--surface);">No workstreams match the current filters.</td></tr>`;
    return;
  }
  body.innerHTML = workstreams.map(name=>{
    const cells = stepOrder.map(step=>{
      const row = stepRows.find(r=>r.discipline===name && r.milestone===step);
      const eRating = row ? effectiveRating(row) : null;
      if(!row || eRating===null){
        return `<td><div class="hm-cell" style="background:var(--surface-2);color:var(--ink-soft);" title="${escAttr(step + ' — no comments reviewed yet')}">—</div></td>`;
      }
      const pct = Math.round(eRating*100);
      const eStatus = effectiveStatus(row);
      const bg = colorForStatus(eStatus);
      const fg = textColorForStatus(eStatus);
      const tip = `${step} — ${eStatus} · ${pct}% (A+B) of ${reviewedCount(row)} reviewed comments`;
      return `<td><div class="hm-cell" style="background:${bg};color:${fg};" title="${escAttr(tip)}">${pct}%</div></td>`;
    }).join('');
    const totalRow = workstreamTotals.find(r=>r.discipline===name);
    const totalERating = totalRow ? effectiveRating(totalRow) : null;
    const totalCell = totalERating!==null
      ? `<td><div class="hm-cell" style="background:${colorForStatus(effectiveStatus(totalRow))};color:${textColorForStatus(effectiveStatus(totalRow))};" title="${escAttr('TOTAL — ' + effectiveStatus(totalRow))}">${Math.round(totalERating*100)}%</div></td>`
      : `<td><div class="hm-cell" style="background:var(--surface-2);color:var(--ink-soft);">—</div></td>`;
    return `<tr><td class="hm-disc">${escHtml(shortenLabel(name))}</td>${cells}${totalCell}</tr>`;
  }).join('');
}

/* ===================== ROUNDS COMPARISON (independent of ACTIVE_ROUND — shows all 4 at once) ===================== */
function renderRoundsCompareTab(){
  const discSel = MS_STATE.msRoundsDiscipline;
  const mileSel = MS_STATE.msRoundsMilestone;

  const allDisciplines = getWorkstreamTotals('R1').map(r=>r.discipline).sort(); // RCS tab's own discipline order, sorted for the picker
  const allSteps = ['Step I','Step II','Step III','Step IV'];
  const onChange = ()=>renderRoundsCompareTab();
  buildMultiSelect('msRoundsDiscipline', allDisciplines, 'All Disciplines', onChange);
  buildMultiSelect('msRoundsMilestone', allSteps, 'All Milestones', onChange);

  const overallByRound = {};
  ROUNDS.forEach(rnd=> overallByRound[rnd] = getFilteredOverall(rnd, discSel, mileSel));

  document.getElementById('roundsKpiRow').innerHTML = ROUNDS.map(rnd=>{
    const o = overallByRound[rnd];
    const reviewed = o.a+o.b+o.c+o.d;
    const pct = reviewed ? Math.round((o.rating)*100) : null;
    return `
      <div class="kpi ${reviewed===0 ? '' : (pct<50?'bad':'')}">
        <div class="num">${reviewed.toLocaleString()}</div>
        <div class="lbl">${rnd} — Comments Reviewed</div>
        <div class="sub">${pct===null ? 'No comments reviewed yet' : `${pct}% cleared (A+B) · ${o.status}`}</div>
      </div>`;
  }).join('');

  document.getElementById('criticalKpiRow').innerHTML = ROUNDS.map(rnd=>{
    const o = overallByRound[rnd];
    return `
      <div class="kpi ${o.critTotal>0 ? 'bad' : ''}">
        <div class="num">${o.critTotal.toLocaleString()}</div>
        <div class="lbl">${rnd} — Critical Open Comments</div>
        <div class="sub">${o.high.toLocaleString()} High · ${o.medium.toLocaleString()} Medium · ${o.low.toLocaleString()} Low</div>
      </div>`;
  }).join('');

  if(CHARTS.roundsCompare) CHARTS.roundsCompare.destroy();
  CHARTS.roundsCompare = new Chart(document.getElementById('chartRoundsCompare'), {
    type:'bar',
    data:{
      labels: ROUNDS,
      datasets:[
        {label:'A — Approved', data:ROUNDS.map(r=>overallByRound[r].a), backgroundColor:STATUS_HEX['Approved']},
        {label:'B — Approved w/ Comments', data:ROUNDS.map(r=>overallByRound[r].b), backgroundColor:STATUS_HEX['Approved with Comments']},
        {label:'C — Revise & Resubmit', data:ROUNDS.map(r=>overallByRound[r].c), backgroundColor:STATUS_HEX['Revise & Resubmit']},
        {label:'D — Rejected', data:ROUNDS.map(r=>overallByRound[r].d), backgroundColor:STATUS_HEX['Rejected']}
      ]
    },
    options:baseBarOptions(false)
  });

  if(CHARTS.severityByRound) CHARTS.severityByRound.destroy();
  CHARTS.severityByRound = new Chart(document.getElementById('chartSeverityByRound'), {
    type:'bar',
    data:{
      labels: ROUNDS,
      datasets:[
        {label:'High', data:ROUNDS.map(r=>overallByRound[r].high), backgroundColor:'#b5453f'},
        {label:'Medium', data:ROUNDS.map(r=>overallByRound[r].medium), backgroundColor:'#d98f3c'},
        {label:'Low', data:ROUNDS.map(r=>overallByRound[r].low), backgroundColor:'#9aa688'}
      ]
    },
    options:baseBarOptions(false)
  });

  const workstreams = discSel.size>0 ? allDisciplines.filter(d=>discSel.has(d)) : allDisciplines;
  const head = document.getElementById('roundsMatrixHead');
  head.innerHTML = '<th>Discipline</th>' + ROUNDS.map(r=>`<th style="text-align:right;">${r} Reviewed</th><th>${r} Status</th>`).join('');

  const body = document.getElementById('roundsMatrixBody');
  body.innerHTML = (workstreams.length===0 ? '' : workstreams.map(name=>{
    const cells = ROUNDS.map(rnd=>{
      const row = getFilteredDisciplineAgg(rnd, name, mileSel);
      const reviewed = reviewedCount(row);
      const status = effectiveStatus(row);
      const tip = `A:${row.a} · B:${row.b} · C:${row.c} · D:${row.d}`;
      const display = reviewed>0 ? reviewed.toLocaleString() : '–';
      const totalCell = `<td style="text-align:right;" title="${escAttr(rnd + ' — ' + tip)}">${display}</td>`;
      const statusCell = `<td>${status ? `<span class="status-chip" style="background:${colorForStatus(status)};color:${textColorForStatus(status)};">${escHtml(status)}</span>` : '<span style="color:var(--ink-soft);">—</span>'}</td>`;
      return totalCell + statusCell;
    }).join('');
    return `<tr><td>${escHtml(shortenLabel(name))}</td>${cells}</tr>`;
  }).join('')) || `<tr><td colspan="${1+ROUNDS.length*2}" style="text-align:center;color:var(--ink-soft);padding:24px;">No workstreams match the current filters.</td></tr>`;
}

function escHtml(s){ return String(s===null||s===undefined?'':s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function escAttr(s){ return escHtml(s); }

/* ===================== EVENTS ===================== */
document.getElementById('themeToggle').addEventListener('click', ()=>{
  setTheme(isDarkMode() ? 'light' : 'dark');
});
document.getElementById('btnUploadTop').addEventListener('click', ()=>document.getElementById('fileInput').click());
document.getElementById('btnUploadCenter').addEventListener('click', ()=>document.getElementById('fileInput').click());
document.getElementById('fileInput').addEventListener('change', e=>{
  if(e.target.files && e.target.files[0]) handleFile(e.target.files[0]);
});

const dz = document.getElementById('dropZone');
['dragenter','dragover'].forEach(ev=>dz.addEventListener(ev, e=>{e.preventDefault(); dz.classList.add('dragover');}));
['dragleave','drop'].forEach(ev=>dz.addEventListener(ev, e=>{e.preventDefault(); dz.classList.remove('dragover');}));
dz.addEventListener('drop', e=>{
  const f = e.dataTransfer.files && e.dataTransfer.files[0];
  if(f) handleFile(f);
});

document.querySelectorAll('.viewnav button').forEach(btn=>{
  btn.addEventListener('click', ()=>switchView(btn.dataset.view));
});

document.querySelectorAll('.round-pill').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    if(RCS_DATA) setActiveRound(btn.dataset.round);
  });
});

['filterStatus'].forEach(id=>{
  document.getElementById(id).addEventListener('change', renderTable);
});
document.getElementById('filterSearch').addEventListener('input', renderTable);

function handleFile(file){
  const reader = new FileReader();
  const emptyHint = document.getElementById('emptyHint');
  emptyHint.textContent = 'Reading "' + file.name + '"…';
  emptyHint.style.color = 'var(--ink-soft)';

  reader.onload = (e) => {
    try{
      const wb = XLSX.read(e.target.result, {type:'array'});
      const parsed = parseWorkbook(wb, file.name);
      document.getElementById('fileMeta').innerHTML = `<b>${escHtml(file.name)}</b><br>Loaded ${new Date().toLocaleString()}`;
      renderAll(parsed);
    }catch(err){
      emptyHint.textContent = 'Could not parse this file: ' + err.message;
      emptyHint.style.color = '#e08080';
      console.error(err);
    }
  };
  reader.onerror = () => {
    emptyHint.textContent = 'Could not read this file. Please try again.';
    emptyHint.style.color = '#e08080';
  };
  reader.readAsArrayBuffer(file);
}
</script>
</body>
</html>
