<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BDMP Review &amp; Comment Sheet — Control Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>
<style>

/* ============ TOKENS ============ */
:root{
  --navy-950:#0d1a30;
  --navy-900:#142a4d;
  --navy-800:#1f3864;
  --navy-700:#2e5496;
  --navy-600:#3d6bb5;
  --gold-500:#c9a84c;
  --gold-400:#ddc278;
  --gold-200:#f1e6c8;
  --paper:#f5f3ee;
  --paper-dim:#eae6dc;
  --ink:#1a2233;
  --ink-soft:#5b6478;
  --line:#d9d3c2;

  --status-a:#92D050;   /* Approved */
  --status-b:#FFFF00;   /* Approved w/ comments */
  --status-c:#FFC000;   /* Revise & resubmit */
  --status-d:#FF0000;   /* Rejected */
  --status-n:#a8a39a;   /* No data */

  --sev-critical:#7a1f1f;
  --sev-high:#b5453f;
  --sev-medium:#d98f3c;
  --sev-low:#9aa688;

  --radius:3px;
  --font-display:'Iowan Old Style','Sitka Text','Georgia',serif;
  --font-body:'Inter','Segoe UI',system-ui,-apple-system,sans-serif;
  --font-mono:'IBM Plex Mono','SF Mono',Consolas,monospace;

  --bg: var(--paper);
  --surface: #ffffff;
  --surface-2: var(--paper-dim);
  --text: var(--ink);
  --text-soft: var(--ink-soft);
  --border: var(--line);
  --chart-grid: #eae6dc;
  --shadow: 0 1px 2px rgba(20,30,50,0.04);
}

html[data-theme="dark"]{
  --bg: #0a1426;
  --surface: #122140;
  --surface-2: #0f1c34;
  --text: #eef1f7;
  --text-soft: #93a0bc;
  --border: #29406b;
  --chart-grid: #213357;
  --shadow: 0 1px 3px rgba(0,0,0,0.4);

  --paper: #0a1426;
  --paper-dim: #0f1c34;
  --ink: #eef1f7;
  --ink-soft: #93a0bc;
  --line: #29406b;
}

*{box-sizing:border-box;margin:0;padding:0;}
html,body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:14px;line-height:1.5;}
html{transition:background 0.2s ease;}
::selection{background:var(--gold-200);}

::-webkit-scrollbar{height:8px;width:8px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px;}

button{font-family:inherit;cursor:pointer;}
table{border-collapse:collapse;width:100%;}

/* ============ TOP BAR ============ */
.topbar{
  background:linear-gradient(180deg,var(--navy-800) 0%, var(--navy-900) 100%);
  color:#fff;
  padding:18px 28px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
  border-bottom:3px solid var(--gold-500);
  position:sticky;top:0;z-index:50;
}
.brand{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;}
.brand .mark{
  font-family:var(--font-display);
  font-size:22px;
  letter-spacing:0.5px;
  font-weight:700;
}
.brand .mark em{color:var(--gold-400);font-style:normal;}
.brand .ref{
  font-family:var(--font-mono);
  font-size:10.5px;
  letter-spacing:0.06em;
  color:var(--gold-200);
  opacity:0.85;
  text-transform:uppercase;
}
.topbar-right{display:flex;align-items:center;gap:14px;}
.file-meta{
  font-family:var(--font-mono);
  font-size:11px;
  color:var(--gold-200);
  text-align:right;
  line-height:1.4;
  opacity:0.9;
}
.file-meta b{color:#fff;font-weight:600;}

.btn-upload{
  background:var(--gold-500);
  color:var(--navy-950);
  border:none;
  padding:9px 18px;
  font-size:12.5px;
  font-weight:700;
  letter-spacing:0.04em;
  text-transform:uppercase;
  border-radius:var(--radius);
  transition:background 0.15s ease;
  display:flex;align-items:center;gap:8px;
}
.btn-upload:hover{background:var(--gold-400);}
.btn-upload svg{width:14px;height:14px;}
#fileInput{display:none;}

/* ============ THEME TOGGLE ============ */
.theme-toggle{
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.18);
  color:#fff;
  width:34px;height:34px;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:background 0.15s ease;
  flex-shrink:0;
}
.theme-toggle:hover{background:rgba(255,255,255,0.16);}
.theme-toggle svg{width:16px;height:16px;}
.theme-toggle .icon-moon{display:none;}
html[data-theme="dark"] .theme-toggle .icon-sun{display:none;}
html[data-theme="dark"] .theme-toggle .icon-moon{display:block;}

/* ============ NAV TABS ============ */
.viewnav{
  display:flex;
  gap:2px;
  background:var(--navy-950);
  padding:0 28px;
  border-bottom:1px solid var(--navy-700);
}
.viewnav button{
  background:transparent;
  border:none;
  color:rgba(255,255,255,0.55);
  padding:13px 20px;
  font-size:12.5px;
  font-weight:600;
  letter-spacing:0.05em;
  text-transform:uppercase;
  border-bottom:2px solid transparent;
  transition:all 0.15s ease;
}
.viewnav button:hover{color:rgba(255,255,255,0.85);}
.viewnav button.active{color:#fff;border-bottom-color:var(--gold-500);}

/* ============ ROUND SELECTOR ============ */
.round-selector{
  display:flex;
  align-items:center;
  gap:10px;
  background:var(--navy-900);
  padding:10px 28px;
  border-bottom:1px solid var(--navy-700);
  flex-wrap:wrap;
}
.round-selector-lbl{
  font-size:10.5px;
  text-transform:uppercase;
  letter-spacing:0.06em;
  color:rgba(255,255,255,0.5);
  font-weight:700;
}
.round-pill{
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.15);
  color:rgba(255,255,255,0.7);
  padding:5px 16px;
  border-radius:14px;
  font-size:12px;
  font-weight:700;
  letter-spacing:0.03em;
  transition:all 0.15s ease;
}
.round-pill:hover{background:rgba(255,255,255,0.12);color:#fff;}
.round-pill.active{background:var(--gold-500);border-color:var(--gold-500);color:var(--navy-950);}
.round-selector-hint{font-size:11px;color:rgba(255,255,255,0.35);margin-left:6px;}

/* ============ LAYOUT ============ */
.view{display:none;padding:28px;max-width:1480px;margin:0 auto;}
.view.active{display:block;animation:fadeIn 0.3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}

.section-label{
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--ink-soft);
  display:flex;
  align-items:center;
  gap:10px;
  margin:32px 0 14px;
}
.section-label::after{content:'';flex:1;height:1px;background:var(--line);}
.section-label:first-child{margin-top:0;}

/* ============ KPI CARDS ============ */
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;}
.kpi{
  background:var(--surface);
  border:1px solid var(--line);
  border-left:3px solid var(--navy-800);
  padding:18px 20px;
  border-radius:var(--radius);
  position:relative;
}
.kpi.warn{border-left-color:var(--status-c);}
.kpi.bad{border-left-color:var(--status-d);}
.kpi .num{
  font-family:var(--font-display);
  font-size:34px;
  font-weight:700;
  line-height:1;
  color:var(--text);
}
.kpi.bad .num{color:var(--sev-high);}
.kpi .lbl{
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:0.05em;
  color:var(--ink-soft);
  margin-top:6px;
  font-weight:600;
}
.kpi .sub{font-size:11.5px;color:var(--ink-soft);margin-top:3px;}

/* ============ RATING CARDS (Stage / Milestone) ============ */
#milestoneRatingRow{grid-template-columns:repeat(4,1fr);}
#stageRatingRow{grid-template-columns:repeat(4,1fr);gap:14px;display:grid;}
.rating-card{
  background:var(--surface);
  border:1px solid var(--line);
  border-top:5px solid var(--navy-800);
  border-radius:var(--radius);
  padding:16px 18px;
  position:relative;
}
.rating-card .step-lbl{
  font-size:10.5px;
  text-transform:uppercase;
  letter-spacing:0.08em;
  color:var(--ink-soft);
  font-weight:700;
}
.rating-card .pct{
  font-family:var(--font-display);
  font-size:30px;
  font-weight:700;
  color:var(--text);
  margin-top:6px;
  line-height:1;
}
.rating-card .pct-lbl{font-size:10.5px;color:var(--ink-soft);margin-top:2px;}
.rating-chip{
  display:inline-block;
  margin-top:10px;
  padding:4px 11px;
  border-radius:10px;
  font-size:11px;
  font-weight:700;
  letter-spacing:0.02em;
}
.rating-card.no-data{opacity:0.55;}
.rating-card.no-data .pct{color:var(--ink-soft);}

/* ============ PANEL / CHART CONTAINERS ============ */
.grid-2{display:grid;grid-template-columns:1.3fr 1fr;gap:16px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
.panel{
  background:var(--surface);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:18px 20px 14px;
}
.panel h3{
  font-family:var(--font-display);
  font-size:15.5px;
  font-weight:700;
  color:var(--text);
  margin-bottom:2px;
}
.panel .panel-sub{font-size:11.5px;color:var(--ink-soft);margin-bottom:14px;}
.chart-wrap{position:relative;width:100%;}
.chart-wrap.h280{height:280px;}
.chart-wrap.h320{height:320px;}
.chart-wrap.h220{height:220px;}

/* legend dots */
.legend-row{display:flex;gap:14px;flex-wrap:wrap;margin-top:10px;font-size:11px;color:var(--ink-soft);}
.legend-row span{display:inline-flex;align-items:center;gap:5px;}
.dot{width:9px;height:9px;border-radius:50%;display:inline-block;border:1px solid rgba(0,0,0,0.15);}

/* ============ CONTROLS (sort/filter) ============ */
.controls-row{display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap;}
.controls-row select, .controls-row input[type=text]{
  font-family:var(--font-body);
  font-size:12px;
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:7px 10px;
  background:var(--surface);
  color:var(--ink);
}
.controls-row label{font-size:11px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:0.04em;font-weight:600;}
.controls-row .grp{display:flex;align-items:center;gap:6px;}
.controls-row input[type=text]{min-width:200px;}

/* ============ MULTI-SELECT DROPDOWN ============ */
.multiselect{position:relative;}
.ms-toggle{
  font-family:var(--font-body);
  font-size:12px;
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:7px 30px 7px 10px;
  background:var(--surface);
  color:var(--ink);
  min-width:160px;
  text-align:left;
  position:relative;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.ms-toggle::after{
  content:'▾';
  position:absolute;
  right:10px;
  top:50%;
  transform:translateY(-50%);
  color:var(--ink-soft);
  font-size:10px;
}
.ms-toggle:hover{border-color:var(--navy-600);}
.ms-toggle.has-selection{border-color:var(--navy-700);color:var(--navy-800);font-weight:600;}
html[data-theme="dark"] .ms-toggle.has-selection{color:var(--gold-400);}
.ms-panel{
  position:absolute;
  top:calc(100% + 4px);
  left:0;
  background:var(--surface);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:0 6px 18px rgba(13,26,48,0.18);
  min-width:240px;
  max-height:300px;
  overflow-y:auto;
  z-index:40;
  display:none;
  padding:8px;
}
.ms-panel.open{display:block;}
.ms-actions{display:flex;gap:12px;padding-bottom:6px;margin-bottom:6px;border-bottom:1px solid var(--line);}
.ms-actions button{background:transparent;border:none;color:var(--navy-700);font-size:11px;font-weight:700;text-decoration:underline;padding:2px 0;text-transform:uppercase;letter-spacing:0.03em;}
html[data-theme="dark"] .ms-actions button{color:var(--gold-400);}
.ms-actions button:hover{opacity:0.75;}
.ms-option{display:flex;align-items:center;gap:8px;padding:6px 6px;font-size:12.5px;border-radius:2px;cursor:pointer;user-select:none;}
.ms-option:hover{background:var(--paper-dim);}
.ms-option input{cursor:pointer;flex-shrink:0;}

/* ============ TABLE ============ */
.table-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--radius);}
table.rcs-table{font-size:12.5px;}
table.rcs-table thead th{
  background:var(--navy-800);
  color:#fff;
  text-align:left;
  padding:10px 12px;
  font-size:10.5px;
  text-transform:uppercase;
  letter-spacing:0.05em;
  font-weight:600;
  position:sticky;top:0;
  cursor:pointer;
  white-space:nowrap;
  user-select:none;
}
table.rcs-table thead th:hover{background:var(--navy-700);}
table.rcs-table thead th .arrow{opacity:0.5;margin-left:4px;font-size:9px;}
table.rcs-table tbody td{
  padding:8px 12px;
  border-bottom:1px solid var(--paper-dim);
  white-space:nowrap;
}
table.rcs-table tbody tr:hover{background:var(--paper-dim);}
table.rcs-table tbody tr.row-total{background:var(--surface-2);font-weight:700;}
table.rcs-table tbody tr.row-total td{border-top:1px solid var(--line);}

.status-chip{
  display:inline-block;
  padding:3px 9px;
  border-radius:10px;
  font-size:10.5px;
  font-weight:700;
  color:#fff;
  letter-spacing:0.02em;
  white-space:nowrap;
}

.crit-badge{
  display:inline-flex;
  align-items:center;
  gap:4px;
  font-weight:700;
  font-family:var(--font-mono);
}
.crit-badge.has-crit{color:var(--sev-critical);}

/* ============ HEATMAP ============ */
table.heatmap-table{font-size:12px;}
table.heatmap-table thead th{
  background:var(--navy-800); color:#fff; padding:9px 10px; font-size:10.5px;
  text-transform:uppercase; letter-spacing:0.04em; text-align:center; white-space:nowrap;
}
table.heatmap-table thead th:first-child{ text-align:left; position:sticky; left:0; z-index:2; }
table.heatmap-table tbody td{ padding:0; border-bottom:1px solid var(--paper-dim); text-align:center; }
table.heatmap-table tbody td.hm-disc{
  text-align:left; padding:8px 12px; white-space:nowrap; font-size:11.5px;
  background:var(--surface); position:sticky; left:0; border-right:1px solid var(--line);
}
table.heatmap-table tbody tr:hover td.hm-disc{background:var(--paper-dim);}
.hm-cell{
  display:flex; align-items:center; justify-content:center;
  height:38px; font-weight:700; font-size:11px; cursor:default;
}

/* ============ EMPTY STATE ============ */
.empty-state{
  min-height:70vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:60px 20px;
}
.empty-state .ring{
  width:84px;height:84px;border-radius:50%;
  border:2px dashed var(--line);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:22px;
  color:var(--gold-500);
}
.empty-state .ring svg{width:34px;height:34px;}
.empty-state h2{
  font-family:var(--font-display);
  font-size:22px;
  color:var(--text);
  margin-bottom:8px;
}
.empty-state p{color:var(--ink-soft);font-size:13.5px;max-width:460px;margin-bottom:22px;}
.empty-state .btn-upload{padding:12px 26px;font-size:13px;}
.empty-state .hint{font-size:11px;color:var(--ink-soft);margin-top:14px;font-family:var(--font-mono);}
.drop-zone.dragover{outline:2px dashed var(--gold-500);outline-offset:8px;border-radius:8px;}

/* ============ FOOTER NOTE ============ */
.foot-note{
  font-size:11px;color:var(--ink-soft);text-align:center;padding:24px 0 10px;font-family:var(--font-mono);
}

/* responsive */
@media (max-width:1100px){
  .kpi-row{grid-template-columns:repeat(2,1fr);}
  #milestoneRatingRow, #stageRatingRow{grid-template-columns:repeat(2,1fr);}
  .grid-2,.grid-3{grid-template-columns:1fr;}
}

/* focus visibility */
button:focus-visible, select:focus-visible, input:focus-visible, th:focus-visible{
  outline:2px solid var(--gold-500);outline-offset:2px;
}
@media (prefers-reduced-motion: reduce){
  *{animation:none !important;transition:none !important;}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="mark">RUA Al Haram <em>BDMP</em></div>
    <div class="ref">Review &amp; Comment Sheet · Control Dashboard</div>
  </div>
  <div class="topbar-right">
    <div class="file-meta" id="fileMeta">No file loaded</div>
    <button class="theme-toggle" id="themeToggle" aria-pressed="false" aria-label="Toggle dark mode" title="Toggle dark mode">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <button class="btn-upload" id="btnUploadTop">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Upload RCS
    </button>
    <input type="file" id="fileInput" accept=".xlsx,.xls">
  </div>
</div>

<div class="viewnav" id="viewnav" style="display:none;">
  <button class="active" data-view="overview">Overview</button>
  <button data-view="detail">Discipline &amp; Milestone Detail</button>
  <button data-view="rounds">Rounds Comparison</button>
</div>

<div class="round-selector" id="roundSelector" style="display:none;">
  <span class="round-selector-lbl">Viewing round:</span>
  <button class="round-pill active" data-round="R1">R1</button>
  <button class="round-pill" data-round="R2">R2</button>
  <button class="round-pill" data-round="R3">R3</button>
  <button class="round-pill" data-round="Final">Final</button>
  <span class="round-selector-hint">Applies to Overview and Discipline &amp; Milestone Detail below</span>
</div>

<!-- EMPTY STATE -->
<div id="emptyState" class="view active">
  <div class="empty-state drop-zone" id="dropZone">
    <div class="ring">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    </div>
    <h2>Load a Review &amp; Comment Sheet</h2>
    <p>Drop an RCS workbook here, or use the upload button above. The dashboard reads the consolidated <b>RCS tab</b> directly — its R1, R2, R3, and Final review-summary blocks — rather than the 23 individual workstream tabs, so it stays in sync with the workbook's own computed ratings and statuses.</p>
    <button class="btn-upload" id="btnUploadCenter">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Choose File
    </button>
    <div class="hint" id="emptyHint">Expected format: RUA BDMP RCS workbook with an "RCS" tab containing R1/R2/R3/Final review-summary blocks</div>
  </div>
</div>

<!-- OVERVIEW -->
<div id="view-overview" class="view">
  <div class="section-label">Programme KPIs</div>
  <div class="kpi-row" id="kpiRow"></div>

  <div class="section-label">Approval Status by Stage</div>
  <div class="kpi-row" id="stageRatingRow"></div>

  <div class="section-label">Approval Status by Milestone — Baseline Stage</div>
  <div class="panel-sub" style="margin:-6px 0 14px;">Based on (A + B) share of total comments per milestone, taken directly from the RCS tab's own computed Rating/Status columns: ≥90% Approved · 75–89% Approved with Comments · 50–74% Revise &amp; Resubmit · &lt;50% Rejected</div>
  <div class="kpi-row" id="milestoneRatingRow"></div>

  <div class="section-label">Approval Progression by Milestone</div>
